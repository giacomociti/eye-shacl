@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .
@prefix shsh: <http://www.w3.org/ns/shacl-shacl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@prefix this: <http://eye-shacl#> .


# shapes identification

{ 
    ?shape ?constraintParameter [].
    ?constraintParameter list:in (
        sh:class sh:nodeKind sh:datatype sh:minCount sh:maxCount 
        sh:minExclusive sh:minInclusive sh:maxExclusive sh:maxInclusive sh:minLength sh:maxLength 
        sh:pattern sh:languageIn sh:uniqueLang sh:equals sh:disjoint sh:lessThan sh:lessThanOrEquals
        sh:not sh:and sh:or sh:xone sh:node sh:property sh:qualifiedValueShape sh:qualifiedMinCount sh:qualifiedMaxCount
        sh:closed sh:ignoredProperties sh:hasValue sh:in
    ) .
    ?SCOPE log:notIncludes { ?shape sh:deactivated true }
} => { ?shape a this:Shape } .

{ ?shape a this:Shape ; sh:path []} => { ?shape a this:PropertyShape } .

{
    ?shape a this:Shape .
    ?SCOPE log:notIncludes { ?shape sh:path [] } .
} => { ?shape a this:NodeShape } .

# severity

{ ?shape this:severity ?severity } <= { ?shape sh:severity ?severity } .
{ ?shape this:severity sh:Violation } <= { ?SCOPE log:notIncludes { ?shape sh:severity [] } }.

# result message
{ (?shape ?defaultMessage) this:resultMessage ?message } <= { ?shape sh:message [ this:quote ?message ] } .
{ (?shape ?defaultMessage) this:resultMessage ?defaultMessage } <= { ?SCOPE log:notIncludes { ?shape sh:message [] } } .

# targets

{ ?shape this:target ?sparql } <= { 
    ?shape sh:targetClass [ log:uri ?targetClassUri ] .
    ("?focusNode rdf:type/rdfs:subClassOf* <%s> ." ?targetClassUri) string:format ?sparql .
} .

{ ?shape this:target ?sparql } <= { 
    ?shape a sh:NodeShape , rdfs:Class ; log:uri ?shapeUri .
    ("?focusNode rdf:type/rdfs:subClassOf* <%s> ." ?shapeUri) string:format ?sparql .
} .

{ ?shape this:target ?sparql } <= { 
    ?shape sh:targetSubjectsOf [ log:uri ?predicateUri ] .
    ("{ SELECT DISTINCT ?focusNode WHERE { ?focusNode <%s> [] } }" ?predicateUri) string:format ?sparql .
} .

{ ?shape this:target ?sparql } <= { 
    ?shape sh:targetObjectsOf [ log:uri ?predicateUri ] .
    ("{ SELECT DISTINCT ?focusNode WHERE { [] <%s> ?focusNode } }" ?predicateUri) string:format ?sparql .
} .

{ ?shape this:target ?sparql } <= { 
    (?x { ?shape sh:targetNode ?x } ?targetNodes) log:collectAllIn ?SCOPE .
    ?targetNodes list:length [ math:greaterThan 0 ] .
    (?targetNodes this:formatNode) list:map ?nodeStrings .
    (?nodeStrings " " ) string:join ?values .
    ("VALUES ?focusNode { %s }" ?values) string:format ?sparql .
} .

{ ?shape this:target ?target } <= { [] a this:Shape ; sh:property ?shape ; this:target ?target } .


# generates a SPARQL query for shapes with target definitions
{ 
    ?shape a this:Shape .
    ?shape this:target ?target .
    ?shape this:severity ?severity .
    ?shape this:constructResultPath ?constructResultPath .

    (?x { ?shape this:constraintClause ?x } ?xs) log:collectAllIn ?SCOPE .
    ?xs list:length [ math:greaterThan 0 ] .
    ?xs list:unique ?unique . # why sometimes we have duplicates?
    (?unique "UNION" ) string:join ?constraints .

    ("""
PREFIX sh: <http://www.w3.org/ns/shacl#>    
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
    
CONSTRUCT {
    ?validationResult a sh:ValidationResult ;
        sh:resultSeverity %s ;
        sh:sourceShape %s ;
        sh:sourceConstraintComponent ?sourceConstraintComponent ;
        sh:focusNode ?focusNode ;
        sh:value ?value ;
        %s
        sh:resultMessage ?resultMessage .   
}
WHERE {
    %s
}
    """ ?severity ?shape ?constructResultPath ?constraints) string:format ?sparql .
} => {  
    ?shape this:sparql ?sparql .
} .

# report the result path for property shapes
{ ?shape this:constructResultPath "" } <= { ?shape a this:NodeShape} .
{ ?shape this:constructResultPath ?result } <= {
    ?shape a this:PropertyShape .
    ?shape sh:path ?path .
    ?path this:pathSHACL ?pathSHACL .
    ("sh:resultPath %s ;" ?pathSHACL) string:format ?result 
} .
# for closed shapes, the result path is bound to the predicate that caused the violation
{ ?shape this:constructResultPath "sh:resultPath ?resultPath ;"} <= { ?shape sh:closed true } .

# format Path
{ ?path this:pathSHACL ?result } <= { 
    ?path this:nodeKind sh:IRI .
    ?path log:uri ?uri .
    ("<%s>" ?uri) string:format ?result .
} .
{ ?path this:pathSHACL ?result } <= { 
    (?path this:pathSHACL) list:map ?innerFormats .
    (?innerFormats " ") string:join ?joined .
    ("(%s)" ?joined) string:format ?result .
} .
{ ?path this:pathSHACL ?result } <= { 
    ?path sh:alternativePath ?innerPaths ; this:nodeKind sh:BlankNode .
    (?innerPaths this:pathSHACL) list:map ?innerFormats .
    (?innerFormats " ") string:join ?joined .
    ("[ sh:alternativePath (%s) ]" ?joined) string:format ?result .
} .
{ ?path this:pathSHACL ?result } <= { 
    ?path sh:inversePath ?innerPath ; this:nodeKind sh:BlankNode .
    ?innerPath this:pathSHACL ?innerFormat .
    ("[ sh:inversePath %s ]" ?innerFormat) string:format ?result .
} .
{ ?path this:pathSHACL ?result } <= { 
    ?path sh:zeroOrMorePath ?innerPath ; this:nodeKind sh:BlankNode .
    ?innerPath this:pathSHACL ?innerFormat .
    ("[ sh:zeroOrMorePath %s ]" ?innerFormat) string:format ?result .
} .
{ ?path this:pathSHACL ?result } <= { 
    ?path sh:oneOrMorePath ?innerPath ; this:nodeKind sh:BlankNode .
    ?innerPath this:pathSHACL ?innerFormat .
    ("[ sh:oneOrMorePath %s ]" ?innerFormat) string:format ?result .
} .
{ ?path this:pathSHACL ?result } <= { 
    ?path sh:zeroOrOnePath ?innerPath ; this:nodeKind sh:BlankNode .
    ?innerPath this:pathSHACL ?innerFormat .
    ("[ sh:zeroOrOnePath %s ]" ?innerFormat) string:format ?result .
} .

# generate SPARQL paths from SHACL paths

{ ?path this:pathSPARQL ?result } <= { 
    ?path this:nodeKind sh:IRI .
    ?path log:uri ?uri .
    ("<%s>" ?uri) string:format ?result .
} .
{ ?path this:pathSPARQL ?result } <= { 
    (?path this:pathSPARQL) list:map ?items .
    (?items "/") string:join ?result .
} .
{ ?path this:pathSPARQL ?result } <= { 
    ?path sh:alternativePath ?alternatives .
    (?alternatives this:pathSPARQL) list:map ?inner .
    (?inner " | ") string:join ?result .
} .
{ ?path this:pathSPARQL ?result } <= { 
    ?path sh:inversePath [this:pathSPARQL ?inner] .
    ("^%s" ?inner) string:format ?result .
} .
{ ?path this:pathSPARQL ?result} <= { 
    ?path sh:zeroOrMorePath [this:pathSPARQL ?inner] .
    ("(%s)*" ?inner) string:format ?result .
} .
{ ?path this:pathSPARQL ?result} <= { 
    ?path sh:oneOrMorePath [this:pathSPARQL ?inner] .
    ("(%s)+" ?inner) string:format ?result .
} .
{ ?path this:pathSPARQL ?result} <= { 
    ?path sh:zeroOrOnePath [this:pathSPARQL ?inner] .
    ("(%s)?" ?inner) string:format ?result .
} .


# many constraints have the same structure, we can generate them with the same rule
# relying on a predicate `this:valueConstraint` that checks a value `?x`
{ ?shape this:constraintClause ?nodeConstraint } <= { 
    ?shape a this:Shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?shape this:valueConstraint (?constraint ?component ?defaultMessage) .
    (?shape ?defaultMessage) this:resultMessage ?message .
    ("""
    {
        %s
        %s
        BIND(?value AS ?x)

        %s

        BIND(BNODE() AS ?validationResult)
        BIND(%s AS ?sourceConstraintComponent) 
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?bindValue ?constraint ?component ?message) string:format ?nodeConstraint .
} .

# value nodes, see https://www.w3.org/TR/shacl/#value-nodes

{ ?shape this:bindValue "BIND(?focusNode AS ?value)" } <= { ?shape a this:NodeShape } .
{ ?shape this:bindValue ?bindValue } <= {
    ?shape a this:PropertyShape .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ("?focusNode %s ?value ." ?pathSPARQL) string:format ?bindValue 
} .

# for inner constraints (nested in sh:or, sh:node etc..) 
# we generate SPARQL from the list of nested shapes
# Bindings for ?x depend on all the `sh:path` in this chain of shapes

# there are no property shapes involved
{ ?shapes this:bindX "BIND(?value AS ?x)"} <= { (?shapes sh:path) list:map () } .

# only the first shape is a property shape
{ ?shapes this:bindX "BIND(?value AS ?x)" } <= {
    ?shapes list:reverse ?reversed .
    ?reversed list:firstRest (?first ?rest) .
    ?first sh:path [] .
    (?rest sh:path) list:map () .
} .

# there are inner property shapes
{ ?shapes this:bindX ?bindX } <= {
    ?shapes list:reverse ?reversed .
    ?reversed list:firstRest (?first ?rest) .
    (?rest sh:path) list:map ?innerPaths .
    ?innerPaths list:length [ math:greaterThan 0 ] .
    ?innerPaths this:joinPaths ?innerPathString .
    ("?value %s ?x ." ?innerPathString) string:format ?bindX 
} .

# collects multiple inner constraints (e.g. in sh:or) into a single SPARQL string with UNIONs
{ ?shapes this:innerConstraints ?constraints } <= { 
    ((?shapes) this:innerConstraint) list:map ?innerConstraints .
    ?innerConstraints list:unique ?unique . # what causes duplicates? (core/property/node-001.ttl)
    (?unique "UNION") string:join ?constraints .
    ?joined this:wrapInBraces ?constraints .
} .


{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape this:valueConstraint (?innerConstraint [] []) .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?shapes this:bindX ?bindX .

    ("""
    {
        SELECT ?focusNode ?value ?shape 
        WHERE 
        {
            %s
            %s
            %s
            %s
        }
    }
    """ ?target ?bindValue ?bindX ?innerConstraint) string:format ?constraint
} .

# inner property shapes
{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:property ?property .
    ?nextList list:firstRest (?property ?shapes) .
    ?nextList this:innerConstraint ?constraint .
} .

## constraint components


# ClassConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:ClassConstraintComponent ?message)} <= { 
    ?shape sh:class ?class .
    ("FILTER NOT EXISTS { ?x rdf:type/rdfs:subClassOf* %s }" ?class) string:format ?constraint .
    ("value should be an instance of %s" ?class) string:format [ this:quote ?message] .
} .

# DatatypeConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:DatatypeConstraintComponent ?message)} <= { 
    ?shape sh:datatype ?datatype . # we should also check that is not ill-typed
    ("FILTER (!isLiteral(?x) || datatype(?x) != %s)" ?datatype) string:format ?constraint .
    ("value should have datatype %s" ?datatype) string:format [ this:quote ?message] .
} .

# NodeKindConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:NodeKindConstraintComponent ?message)} <= { 
    ?shape this:nodeKindFilter ?constraint .
    ?shape this:nodeKindMessage [ this:quote ?message ] .
} .

{ ?shape this:nodeKindFilter "FILTER (!isIRI(?x))" } <= { ?shape sh:nodeKind sh:IRI } .
{ ?shape this:nodeKindFilter "FILTER (!isLiteral(?x))" } <= { ?shape sh:nodeKind sh:Literal } .
{ ?shape this:nodeKindFilter "FILTER (!isBlank(?x))" } <= { ?shape sh:nodeKind sh:BlankNode } .
{ ?shape this:nodeKindFilter "FILTER (!isIRI(?x) && !isLiteral(?x))" } <= { ?shape sh:nodeKind sh:IRIOrLiteral } .
{ ?shape this:nodeKindFilter "FILTER (!isBlank(?x) && !isLiteral(?x))" } <= { ?shape sh:nodeKind sh:BlankNodeOrLiteral } .
{ ?shape this:nodeKindFilter "FILTER (!isBlank(?x) && !isIRI(?x))" } <= { ?shape sh:nodeKind sh:BlankNodeOrIRI } .

{ ?shape this:nodeKindMessage "value should be an IRI" } <= { ?shape sh:nodeKind sh:IRI } .
{ ?shape this:nodeKindMessage "value should be a literal" } <= { ?shape sh:nodeKind sh:Literal } .
{ ?shape this:nodeKindMessage "value should be a blank node" } <= { ?shape sh:nodeKind sh:BlankNode } .
{ ?shape this:nodeKindMessage "value should be an IRI or a literal" } <= { ?shape sh:nodeKind sh:IRIOrLiteral } .
{ ?shape this:nodeKindMessage "value should be a blank node or a literal" } <= { ?shape sh:nodeKind sh:BlankNodeOrLiteral } .
{ ?shape this:nodeKindMessage "value should be a blank node or an IRI" } <= { ?shape sh:nodeKind sh:BlankNodeOrIRI } .

# MinCountConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:minCount ?minCount .
    ?shape this:target ?target .
    ?minCount math:greaterThan 0 .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    "no value found" this:quote ?defaultMessage .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        %s
        BIND(?focusNode AS ?x)

        FILTER NOT EXISTS { ?x %s [] }

        BIND(BNODE() AS ?validationResult)
        BIND(sh:MinCountConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?pathSPARQL ?resultMessage) string:format ?constraint .
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?first ?rest) .
    ?first sh:minCount [ math:greaterThan 0 ] ; sh:path ?path .
    ?shapes list:last [ this:target ?target ; this:bindValue ?bindValue ] .
    ?rest this:bindX ?bindX .
    ?path this:pathSPARQL ?pathSPARQL .
    ("""
    {
        SELECT ?focusNode ?value # sh:MinCountConstraintComponent
        WHERE {
            %s
            %s
            %s
            FILTER NOT EXISTS { ?x %s [] }
        }
    }
    """ ?target ?bindValue ?bindX ?pathSPARQL) string:format ?constraint .
} .

{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:minCount ?minCount .
    ?shape this:target ?target .
    ?minCount math:greaterThan 1 .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    (?shape """CONCAT("too few values: ", STR(?count))""") this:resultMessage ?resultMessage .
    ("""
    {
        %s
        BIND(?focusNode AS ?x)

        {
            SELECT ?x (COUNT(?value) AS ?count)
            WHERE { ?x %s ?value } 
            GROUP BY ?x
            HAVING (COUNT(?value) < %s)
        }

        BIND(BNODE() AS ?validationResult)
        BIND(sh:MinCountConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?pathSPARQL ?minCount ?resultMessage) string:format ?constraint .
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?first ?rest) .
    ?first sh:minCount ?minCount ; sh:path ?path .
    ?minCount math:greaterThan 1 .
    ?shapes list:last [ this:target ?target ; this:bindValue ?bindValue ] .
    ?rest this:bindX ?bindX .
    ?path this:pathSPARQL ?pathSPARQL .
    ("""
    {
        SELECT ?focusNode ?value # sh:MinCountConstraintComponent
        WHERE {
            %s
            %s
            %s
            {
                SELECT ?x
                WHERE { ?x %s ?value } 
                GROUP BY ?x
                HAVING (COUNT(?value) < %s)
            }
        }
    }
    """ ?target ?bindValue ?bindX ?pathSPARQL ?minCount) string:format ?constraint .
} .

# MaxCountConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:maxCount ?maxCount .
    ?shape this:target ?target .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    (?shape """CONCAT("too many values: ", STR(?count))""") this:resultMessage ?resultMessage .
    ("""
    {
        %s
        BIND(?focusNode AS ?x)

        {
            SELECT ?x (COUNT(?value) AS ?count)
            WHERE { ?x %s ?value } 
            GROUP BY ?x
            HAVING (COUNT(?value) > %s)
        }

        BIND(BNODE() AS ?validationResult)
        BIND(sh:MaxCountConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?pathSPARQL ?maxCount ?resultMessage) string:format ?constraint .
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:maxCount ?maxCount .
    ?innerShape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?rest this:bindX ?bindX .
    ("""
    {
        SELECT ?focusNode ?value # MaxCountConstraintComponent
        WHERE {
            %s
            %s
            %s
            {
                SELECT ?x
                WHERE { ?x %s ?value } 
                GROUP BY ?x
                HAVING (COUNT(?value) > %s)
            }
        }
    }
    """ ?target ?bindValue ?bindX ?pathSPARQL ?maxCount) string:format ?constraint .
} .

# MinInclusiveConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:MinInclusiveConstraintComponent ?message) } <= { 
    ?shape sh:minInclusive ?minInclusive .
    ?minInclusive this:formatNode ?minInclusiveFormat ; this:datatype ?datatype .
    ?datatype this:compatibleTypes ?types .
    ("FILTER (!isLiteral(?x) || !(datatype(?x) IN (%s)) || ?x < %s)" ?types ?minInclusiveFormat) string:format ?constraint .
    (?literal []) log:dtlit ?minInclusive .
    ("value should be greater than or equal to %s" ?literal) string:format [ this:quote ?message ] .
} .

# MaxInclusiveConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:MaxInclusiveConstraintComponent ?message) } <= { 
    ?shape sh:maxInclusive ?maxInclusive .
    ?maxInclusive this:formatNode ?maxInclusiveFormat ; this:datatype ?datatype .
    ?datatype this:compatibleTypes ?types .
    ("FILTER (!isLiteral(?x) || !(datatype(?x) IN (%s)) || ?x > %s)" ?types ?maxInclusiveFormat) string:format ?constraint .
    (?literal []) log:dtlit ?maxInclusive .
    ("value should be less than or equal to %s" ?literal) string:format [ this:quote ?message ] .
} .

# MinExclusiveConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:MinExclusiveConstraintComponent ?message) } <= { 
    ?shape sh:minExclusive ?minExclusive .
    ?minExclusive this:formatNode ?minExclusiveFormat ; this:datatype ?datatype .
    ?datatype this:compatibleTypes ?types .
    ("FILTER (!isLiteral(?x) || !(datatype(?x) IN (%s)) || ?x <= %s)" ?types ?minExclusiveFormat) string:format ?constraint .
    (?literal []) log:dtlit ?minExclusive .
    ("value should be greater than %s" ?literal) string:format [ this:quote ?message ] .
} .

# MaxExclusiveConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:MaxExclusiveConstraintComponent ?message) } <= { 
    ?shape sh:maxExclusive ?maxExclusive .
    ?maxExclusive this:formatNode ?maxExclusiveFormat ; this:datatype ?datatype .
    ?datatype this:compatibleTypes ?types .
    ("FILTER (!isLiteral(?x) || !(datatype(?x) IN (%s)) || ?x >= %s)" ?types ?maxExclusiveFormat) string:format ?constraint .
    (?literal []) log:dtlit ?maxExclusive .
    ("value should be less than %s" ?literal) string:format [ this:quote ?message ] .
} .

# MinLengthConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:MinLengthConstraintComponent ?message) } <= { 
    ?shape sh:minLength ?minLength .
    ("FILTER (isBlank(?x) || strlen(str(?x)) < %s)" ?minLength) string:format ?constraint .
    ("value should have length greater than or equal to %s" ?minLength) string:format [ this:quote ?message ] .
} .

# MaxLengthConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:MaxLengthConstraintComponent ?message) } <= { 
    ?shape sh:maxLength ?maxLength .
    ("FILTER (isBlank(?x) || strlen(str(?x)) > %s)" ?maxLength) string:format ?constraint .
    ("value should have length less than or equal to %s" ?maxLength) string:format [ this:quote ?message ] .
} .

# PatternConstraintComponent
{ ?pattern this:regexEscape ?escaped } <= { 
    # not clear why this seems to work
    (?pattern "\\" "\\") string:replace ?escaped
} .

{ ?shape this:valueConstraint (?constraint sh:PatternConstraintComponent ?message) } <= { 
    ?shape sh:pattern ?pattern .
    ?pattern this:regexEscape ?escapedPattern .
    ?SCOPE log:notIncludes { ?shape sh:flags [] } .
    ("""FILTER (isBlank(?x) || !regex(str(?x), "%s"))""" ?escapedPattern) string:format ?constraint .
    "value should match pattern" this:quote [ log:equalTo ?message ] .
} .

{ ?shape this:valueConstraint (?constraint sh:PatternConstraintComponent ?message) } <= { 
    ?shape sh:pattern ?pattern .
    ?pattern this:regexEscape ?escapedPattern .
    ?shape sh:flags ?flags .
    ("FILTER (isBlank(?x) || !regex(str(?x), '%s', '%s'))" ?escapedPattern ?flags) string:format ?constraint .
    "value should match pattern" this:quote [ log:equalTo ?message ] .
} .

# LanguageInConstraintComponent
{ ?lang this:langNotMatches ?clause } <= {  
    ("langMatches(lang(?x), '%s') = false" ?lang) string:format ?clause
} .

{ ?shape this:valueConstraint (?constraint sh:LanguageInConstraintComponent ?message) } <= { 
    ?shape sh:languageIn ?languages .
    (?languages this:langNotMatches) list:map ?clauses .
    (?clauses " && ") string:join ?langs .
    ("FILTER (!isLiteral(?x) || (%s))" ?langs) string:format ?constraint .
    (?languages ", ") string:join ?messageList .
    ("value should have one of the language tags: %s" ?messageList) string:format [ this:quote ?message ] .
} .

# UniqueLangConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:uniqueLang true .
    ?shape this:target ?target .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    (?shape  """CONCAT("language '", ?lang, "' has been used by ", STR(?count), " values")""") this:resultMessage ?resultMessage .
    ("""
    {
        %s
        BIND(?focusNode AS ?x)
        
        {
            SELECT ?x ?lang (COUNT(?lang) AS ?count)
            WHERE { 
                ?x %s ?o 
                BIND(lang(?o) AS ?lang)
                FILTER(?lang != "")
            } 
            GROUP BY ?x ?lang
            HAVING (COUNT(?lang) > 1)
        }

        BIND(BNODE() AS ?validationResult)
        BIND(sh:UniqueLangConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?pathSPARQL ?resultMessage) string:format ?constraint .
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:uniqueLang true .
    ?innerShape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?rest this:bindX ?bindX .
    ("""
    {
        SELECT ?focusNode ?value # UniqueLangConstraintComponent
        WHERE {
            %s
            %s
            %s
            {
                SELECT ?x
                WHERE { 
                    ?x %s ?o 
                    BIND(lang(?o) AS ?lang)
                    FILTER(?lang != "")
                } 
                GROUP BY ?x ?lang
                HAVING (COUNT(?lang) > 1)
            }
        }
    }
    """ ?target ?bindValue ?bindX ?pathSPARQL) string:format ?constraint .
} .

# EqualsConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:equals ?otherPath .
    ?shape this:target ?target .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ("Must have same values as %s" ?otherPath) string:format [ this:quote ?defaultMessage ] .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        %s
        BIND(?focusNode AS ?x)

        {
            { ?x %s ?value } MINUS { ?x %s ?value }
        }
        UNION
        {
            { ?x %s ?value } MINUS { ?x %s ?value } 
        }

        BIND(BNODE() AS ?validationResult)
        BIND(sh:EqualsConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?pathSPARQL ?otherPath ?otherPath ?pathSPARQL ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:equals ?otherPath .
    ?innerShape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?rest this:bindX ?bindX .
    ("""
    {
        SELECT ?focusNode ?value # EqualsConstraintComponent
        WHERE {
            %s
            %s
            %s
            {
                {
                    { ?x %s ?o } MINUS { ?x %s ?o }
                }
                UNION
                {
                    { ?x %s ?o } MINUS { ?x %s ?o } 
                }
            }
        }
    }
    """ ?target ?bindValue ?bindX ?pathSPARQL ?otherPath ?otherPath ?pathSPARQL) string:format ?constraint .
} .

{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:equals ?otherPath .
    ?shape a this:NodeShape .
    ?shape this:target ?target .
    ("Must have same values as %s" ?otherPath) string:format [ this:quote ?defaultMessage ] .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        {
            %s
            { ?focusNode %s ?value . FILTER (?value != ?focusNode) }
        }
        UNION
        {
            %s
            BIND(?focusNode AS ?value)
            FILTER NOT EXISTS { ?focusNode %s ?value . }
        }

        BIND(BNODE() AS ?validationResult)
        BIND(sh:EqualsConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?otherPath ?target ?otherPath ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:equals ?otherPath .
    ?innerShape a this:NodeShape .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?rest this:bindX ?bindX .
    ("""
    {
        SELECT ?focusNode ?value # EqualsConstraintComponent for NodeShape
        WHERE {
            {
                { 
                    %s
                    %s
                    %s
                    ?x %s ?o . FILTER (?o != ?x)     
                }
                UNION
                {
                    %s
                    %s
                    %s
                    FILTER NOT EXISTS { ?x %s ?x }
                }
            }
        }
    }
    """ ?target ?bindValue ?bindX ?otherPath ?target ?bindValue ?bindX ?otherPath) string:format ?constraint
} .


# DisjointConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:disjoint ?otherPath .
    ?shape this:target ?target .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ("Must have no values in common with %s" ?otherPath) string:format [ this:quote ?defaultMessage ] .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        %s

        ?focusNode %s ?value . 
        ?focusNode %s ?value .
    
        BIND(BNODE() AS ?validationResult)
        BIND(sh:DisjointConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?pathSPARQL ?otherPath ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:disjoint ?otherPath .
    ?innerShape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?rest this:bindX ?bindX .
    ("""
    {
        SELECT ?focusNode ?value # DisjointConstraintComponent
        WHERE {
            %s
            %s
            %s
           
            ?x %s ?o . 
            ?x %s ?o .
        }
    }
    """ ?target ?bindValue ?bindX ?pathSPARQL ?otherPath) string:format ?constraint .
} .


{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:disjoint ?otherPath .
    ?shape a this:NodeShape .
    ?shape this:target ?target .
    ("Must have no values in common with %s" ?otherPath) string:format [ this:quote ?defaultMessage ] .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        %s

        BIND(?focusNode AS ?value)
        ?focusNode %s ?value . 
    
        BIND(BNODE() AS ?validationResult)
        BIND(sh:DisjointConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?otherPath ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:disjoint ?otherPath .
    ?innerShape a this:NodeShape .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?rest this:bindX ?bindX .
    ("""
    {
        SELECT ?focusNode ?value # DisjointConstraintComponent
        WHERE {
            %s
            %s
            %s
           
            ?x %s ?x . 
        }
    }
    """ ?target ?bindValue ?bindX ?otherPath) string:format ?constraint .
} .


# LessThanConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:lessThan ?otherPath .
    ?shape this:target ?target .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    (?shape """CONCAT("value is not less than ", STR(?otherValue))""") this:resultMessage ?resultMessage .
    ("""
    {
        %s
        {
            SELECT ?focusNode ?value ?otherValue WHERE {
                ?focusNode %s ?value . 
                ?focusNode %s ?otherValue .
                FILTER NOT EXISTS {
                    FILTER(?value < ?otherValue)
                }
            }
        }
        BIND(BNODE() AS ?validationResult)
        BIND(sh:LessThanConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?pathSPARQL ?otherPath ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:lessThan ?otherPath .
    ?innerShape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?rest this:bindX ?bindX .
    ("""
    {
        SELECT ?focusNode ?value # LessThanConstraintComponent
        WHERE {
            %s
            %s
            %s
           
            ?x %s ?o1 . 
            ?x %s ?o2 .
            FILTER NOT EXISTS {
                FILTER(?o1 < ?o2)
            }
        }
    }
    """ ?target ?bindValue ?bindX ?pathSPARQL ?otherPath) string:format ?constraint .
} .

# LessThanOrEqualsConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:lessThanOrEquals ?otherPath .
    ?shape this:target ?target .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    (?shape """CONCAT("value is not less than or equal to ", STR(?otherValue))""") this:resultMessage ?resultMessage .
    ("""
    {
        %s
        {
            SELECT ?focusNode ?value ?otherValue WHERE {
                ?focusNode %s ?value . 
                ?focusNode %s ?otherValue .
                FILTER NOT EXISTS {
                    FILTER(?value <= ?otherValue)
                }
            }
        }
        BIND(BNODE() AS ?validationResult)
        BIND(sh:LessThanOrEqualsConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?pathSPARQL ?otherPath ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:lessThanOrEquals ?otherPath .
    ?innerShape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?rest this:bindX ?bindX .
    ("""
    {
        SELECT ?focusNode ?value # LessThanOrEqualsConstraintComponent
        WHERE {
            %s
            %s
            %s
           
            ?x %s ?o1 . 
            ?x %s ?o2 .
            FILTER NOT EXISTS {
                FILTER(?o1 <= ?o2)
            }
        }
    }
    """ ?target ?bindValue ?bindX ?pathSPARQL ?otherPath) string:format ?constraint .
} .


# OrConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:or ?alternatives .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    (?shape ?alternatives) this:pairs ?pairs .
    (?pairs this:innerConstraints) list:map ?innerConstraints .
    (?innerConstraints "\n\t\t") string:join ?joined .
    "all OR alternatives failed" this:quote ?defaultMessage .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        %s
        %s

        {
            SELECT DISTINCT ?focusNode ?value WHERE 
            {
                %s
            }
        }
        
        BIND(BNODE() AS ?validationResult)
        BIND(sh:OrConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?bindValue ?joined ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?first ?rest). 
    ?first sh:or ?alternatives .
    (?x {
        ?alternatives list:member ?innerShape .
        ?innerList list:firstRest (?innerShape ?shapes) .
        ?innerList this:innerConstraints ?x .
    } ?xs) log:collectAllIn ?SCOPE .
    (?xs "\n\t\t") string:join ?joined .
    ("""
    {
        SELECT DISTINCT ?focusNode ?value WHERE 
        {
            %s
        }
    }
    """ ?joined) string:format ?constraint .
} .

# NotConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:not ?innerShape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    (?innerShape ?shape) this:innerConstraints ?innerConstraints .
    "value should not conform to the shape" this:quote ?defaultMessage .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        {
            %s
            %s
        }
        MINUS
        {
            %s
        }
        
        BIND(BNODE() AS ?validationResult)
        BIND(sh:NotConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?bindValue ?innerConstraints ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest). 
    ?innerShape sh:not ?not .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?innerList list:firstRest (?not ?shapes) .
    ?innerList this:innerConstraints ?innerConstraints .
    ("""
    {
        {
            %s
            %s
        }
        MINUS
        {
            %s
        }
    }
    """ ?target ?bindValue ?innerConstraints) string:format ?constraint .
} .

# AndConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:and ?innerShapes .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    (?shape ?innerShapes) this:pairs ?pairs .
    (?pairs this:innerConstraints) list:map ?innerConstraints .
    (?innerConstraints "UNION") string:join ?joined .
    "value must conform to all shapes in AND" this:quote ?defaultMessage .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        %s
        %s

        {
            SELECT DISTINCT ?focusNode ?value WHERE 
            {
                %s
            }
        }
        

        BIND(BNODE() AS ?validationResult)
        BIND(sh:AndConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?bindValue ?joined ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?first ?rest). 
    ?first sh:and ?innerShapes .
    (?x {
        ?innerShapes list:member ?innerShape .
        ?innerList list:firstRest (?innerShape ?shapes) .
        ?innerList this:innerConstraints ?x .
    } ?xs) log:collectAllIn ?SCOPE .
    (?xs "UNION") string:join ?joined .
    ("""
    {
        SELECT DISTINCT ?focusNode ?value WHERE 
        {
            %s
        }
    }
    """ ?joined) string:format ?constraint .
} .


# XoneConstraintComponent

{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:xone ?alternatives .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .

    (?x {
        ?alternatives list:member ?innerShape .
        (?innerShape ?shape) this:innerConstraints ?inner .
        ("""
        {
            BIND(%s AS ?shape)
            {
                SELECT DISTINCT ?focusNode ?value 
                WHERE 
                {
                    %s
                }
            }
        }
        """ ?innerShape ?inner) string:format ?x
    } ?innerConstraints) log:collectAllIn ?SCOPE .

    #(?pairs this:innerConstraints) list:map ?innerConstraints .
    (?innerConstraints "UNION") string:join ?joined .

    ?alternatives list:length ?numAlternatives .
    ("""CONCAT(STR(%s - ?count), " shapes conforming instead of 1")""" ?numAlternatives) string:format ?defaultMessage .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        {
            SELECT ?focusNode ?value (COUNT(?shape) AS ?count)
            WHERE {
            {
                %s
                %s
            }
            UNION
            {
                %s
            }
            }
            GROUP BY ?focusNode ?value
            HAVING (COUNT(?shape) != 1)   
        }
        BIND(BNODE() AS ?validationResult)
        BIND(sh:XoneConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?bindValue ?joined ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?first ?rest). 
    ?first sh:xone ?alternatives .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .

    (?x {
        ?alternatives list:member ?innerShape .
        ?innerList list:firstRest (?innerShape ?shapes) .
        ?innerList this:innerConstraints ?inner .
        ("""
        {
            BIND(%s AS ?shape)
            {
                SELECT DISTINCT ?focusNode ?value 
                WHERE 
                {
                    %s
                }
            }
        }
        """ ?innerShape ?inner) string:format ?x
    } ?innerConstraints) log:collectAllIn ?SCOPE .
    (?innerConstraints "UNION") string:join ?joined .

    ("""
    {
        SELECT ?focusNode ?value
        WHERE {
        {
            %s
            %s
        }
        UNION
        {
            %s
        }
        }
        GROUP BY ?focusNode ?value
        HAVING (COUNT(?shape) != 1)   
        
    }
    """ ?target ?bindValue ?joined) string:format ?constraint
} .


# NodeConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:node ?innerShape .
    (?innerShape ?shape) this:innerConstraints ?innerConstraints .
    "value should conform to shape" this:quote ?defaultMessage .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        { 
            SELECT DISTINCT ?focusNode ?value 
            WHERE 
            {
                %s
            }
        }
        BIND(BNODE() AS ?validationResult)
        BIND(sh:NodeConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?innerConstraints ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest). 
    ?innerShape sh:node ?node .
    ?shapes list:last ?shape .
    ?innerList list:firstRest (?node ?shapes) .
    ?innerList this:innerConstraints ?innerConstraints .
    ("""
    {
        SELECT DISTINCT ?focusNode ?value 
        WHERE 
        {
            %s
        }
    }
    """ ?innerConstraints) string:format ?constraint .
} .


# QualifiedValueShapeComponent (todo inner and disjoint)

# QualifiedMinCountConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:qualifiedValueShape ?innerShape .
    ?shape sh:qualifiedMinCount ?minCount .
    ?minCount math:greaterThan 0 .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    (?innerShape ?shape) this:innerConstraints ?innerConstraints .    
    ("""
    {
        %s
        FILTER NOT EXISTS { 
            %s
            %s
            MINUS {
                %s
            }
        }
       
        BIND(BNODE() AS ?validationResult)
        BIND(sh:QualifiedMinCountConstraintComponent AS ?sourceConstraintComponent)
    }
    """ ?target ?target ?bindValue ?innerConstraints) string:format ?constraint
} .

# QualifiedMinCountConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:qualifiedValueShape ?innerShape .
    ?shape sh:qualifiedMinCount ?minCount .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    (?innerShape ?shape) this:innerConstraints ?innerConstraints .    
    ("""
    {
        { 
            SELECT ?focusNode
            WHERE {
                %s
                %s
            MINUS
                %s
            }
            GROUP BY ?focusNode
            HAVING (COUNT(?value) < %s)
            
        }
        BIND(BNODE() AS ?validationResult)
        BIND(sh:QualifiedMinCountConstraintComponent AS ?sourceConstraintComponent)
    }
    """ ?target ?bindValue ?innerConstraints ?minCount) string:format ?constraint
} .

# QualifiedMaxCountConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:qualifiedValueShape ?innerShape .
    ?shape sh:qualifiedMaxCount ?maxCount .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    (?innerShape ?shape) this:innerConstraints ?innerConstraints .    
    ("""
    {
        { 
            SELECT ?focusNode
            WHERE {
                %s
                %s
            MINUS
                %s
            }
            GROUP BY ?focusNode
            HAVING (COUNT(?value) > %s)
            
        }
        BIND(BNODE() AS ?validationResult)
        BIND(sh:QualifiedMaxCountConstraintComponent AS ?sourceConstraintComponent)
    }
    """ ?target ?bindValue ?innerConstraints ?maxCount) string:format ?constraint
} .


# ClosedConstraintComponent

{ ?shape this:allowedProperties ?allowed } <= {
    ?shape a this:Shape ; sh:closed true .
    (?x { ?shape sh:property [ sh:path ?x ] . ?x this:nodeKind sh:IRI } ?existing) log:collectAllIn [] .
    (?x { ?shape sh:ignoredProperties [ list:member ?x ]} ?ignored) log:collectAllIn [] .
    (?existing ?ignored) list:append ?allowed .
} .

{ ?shape this:constraintClause ?constraint } <= { 
    ?shape this:allowedProperties ?allowed .
    ?shape this:target ?target .
    (?allowed this:formatNode) list:map ?allowedFormat .
    (?allowedFormat ", ") string:join ?allowedValues .
    "only allowed predicates should be used" this:quote ?defaultMessage .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        %s

        ?focusNode ?resultPath ?value .
        FILTER(?resultPath NOT IN (%s))
        
        BIND(BNODE() AS ?validationResult)
        BIND(sh:ClosedConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?allowedValues ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest). 
    ?innerShape sh:closed true .
    ?innerShape this:allowedProperties ?allowed .
    (?allowed this:formatNode) list:map ?allowedFormat .
    (?allowedFormat ", ") string:join ?allowedValues .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?rest this:bindX ?bindX .
    
    ("""
    {
        %s
        %s
        %s

        ?x ?p [] .
        FILTER(?p NOT IN (%s))

    }
    """ ?target ?bindValue ?bindX ?allowedValues) string:format ?constraint .
} .


# HasValueConstraintComponent
{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:hasValue ?hasValue .
    ?hasValue this:formatNode ?hasValueFormat .
    ?shape this:target ?target .
    ?shape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    "missing expected value" this:quote ?defaultMessage .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        %s
        BIND(?focusNode AS ?x)

        FILTER NOT EXISTS { ?x %s %s}

        BIND(BNODE() AS ?validationResult)
        BIND(sh:HasValueConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?pathSPARQL ?hasValueFormat ?resultMessage) string:format ?constraint
} .

{ ?shapes this:innerConstraint ?constraint } <= { 
    ?shapes list:firstRest (?innerShape ?rest) .
    ?innerShape sh:hasValue ?hasValue .
    ?shapes list:last ?shape .
    ?shape this:target ?target .
    ?shape this:bindValue ?bindValue .
    ?innerShape sh:path ?path .
    ?path this:pathSPARQL ?pathSPARQL .
    ?rest this:bindX ?bindX .
    ?hasValue this:formatNode ?hasValueFormat .
    
    ("""
    {
        SELECT ?focusNode ?value
        WHERE {
            %s
            %s
            %s

            FILTER NOT EXISTS { ?x %s %s}
        }
    }
    """ ?target ?bindValue ?bindX ?pathSPARQL ?hasValueFormat) string:format ?constraint
} .


{ ?shape this:constraintClause ?constraint } <= { 
    ?shape sh:hasValue ?hasValue .
    ?shape a this:NodeShape .
    ?hasValue this:formatNode ?hasValueFormat .
    ?shape this:target ?target .
    "unexpected value" this:quote ?defaultMessage .
    (?shape ?defaultMessage) this:resultMessage ?resultMessage .
    ("""
    {
        %s

        FILTER(?focusNode != %s)

        BIND(BNODE() AS ?validationResult)
        BIND(sh:HasValueConstraintComponent AS ?sourceConstraintComponent)
        BIND(%s AS ?resultMessage)
    }
    """ ?target ?hasValueFormat ?resultMessage) string:format ?constraint
} .

# InConstraintComponent
{ ?shape this:valueConstraint (?constraint sh:InConstraintComponent ?message) } <= { 
    ?shape sh:in ?items .
    (?items this:formatNode) list:map ?itemStrings .
    (?itemStrings ", ") string:join ?values .
    ("FILTER (?x NOT IN (%s))" ?values) string:format ?constraint .
    "value should be one of the values in the list" this:quote [ log:equalTo ?message ] .
} .

# Utils

{ ?text this:quote ?quoted } <= { ('"%s"' ?text) string:format ?quoted } . # consider escaping quotes in the text

{ ?value this:nodeKind sh:IRI } <= { ?value log:rawType log:Other . ?value log:uri [] }. 
{ ?value this:nodeKind sh:BlankNode } <= { ?value log:rawType log:LabeledBlankNode }. 
{ ?value this:nodeKind sh:BlankNode } <= { ?value log:rawType log:UnlabeledBlankNode }.
{ ?value this:nodeKind sh:BlankNode } <= { ?value log:rawType log:SkolemIRI }.

{ ?value this:datatype ?datatype } <= { ([] ?datatype) log:dtlit ?value }.

xsd:string this:compatibleTypes "xsd:string" .
xsd:dateTime this:compatibleTypes "xsd:dateTime" .
xsd:integer this:compatibleTypes "xsd:integer, xsd:decimal, xsd:double, xsd:float, xsd:int" .
xsd:decimal this:compatibleTypes "xsd:integer, xsd:decimal, xsd:double, xsd:float, xsd:int" .
xsd:double this:compatibleTypes "xsd:integer, xsd:decimal, xsd:double, xsd:float, xsd:int" .
xsd:float this:compatibleTypes "xsd:integer, xsd:decimal, xsd:double, xsd:float, xsd:int" .
xsd:int this:compatibleTypes "xsd:integer, xsd:decimal, xsd:double, xsd:float, xsd:int" .


# generate SPARQL representations of RDF nodes
{ ?node this:formatNode ?format } <= { 
    ?node log:rawType log:Other ; log:uri ?uri . 
    ("<%s>" ?uri) string:format ?format 
} .
{ ?value this:formatNode ?format } <= { 
    (?text xsd:string) log:dtlit ?value .
    ('"%s"' ?text) string:format ?format 
} .
{ ?value this:formatNode ?format } <= { 
    (?text xsd:integer) log:dtlit ?value .
    ('%s' ?text) string:format ?format 
} .
{ ?value this:formatNode ?format } <= { 
    (?text xsd:double) log:dtlit ?value .
    ('"%s"^^%s' ?text xsd:decimal) string:format ?format 
} .
{ ?value this:formatNode ?format } <= { 
    (?text ?datatype) log:dtlit ?value .
    ?datatype log:notEqualTo rdf:langString, xsd:string, xsd:integer, xsd:double .
    ('"%s"^^%s' ?text ?datatype) string:format ?format 
} .
{ ?value this:formatNode ?format } <= { 
    ( ?text ?lang) log:langlit ?value .
    ('"%s"@%s' ?text ?lang) string:format ?format 
} .

{ ?item this:wrapInParents ?wrapped } <= { ("(%s)" ?item) string:format ?wrapped } .
{ ?item this:wrapInBraces ?wrapped } <= { ("{%s}" ?item) string:format ?wrapped } .

{ (?path) this:joinPaths ?result } <= { 
    ("%s" ?path) string:format ?result
}.
{ ?paths this:joinPaths ?result } <= { 
    ?paths list:length [ math:greaterThan 1 ] .
    (?paths this:wrapInParents) list:map ?wrapped .
    (?wrapped " / ") string:join ?result .
} .

# pairs each element in ?list with the same element ?e
{ (?e ()) this:pairs () } <= {  } .
{ (?e ?list) this:pairs ?pairs } <= { 
    ?list list:firstRest (?first ?rest) .
    (?e ?rest) this:pairs ?restPairs .
    ?pairs list:firstRest ((?first ?e) ?restPairs) .
} .

# see https://www.w3.org/TR/shacl/#shapes-recursion
{ 
    ?shape1 [ list:in (sh:property sh:node sh:not sh:qualifiedValueShape) ] ?shape2 .
} 
=> 
{ 
    ?shape1 this:refers ?shape2.
} .

{ 
    ?shape1 [ list:in ( sh:or sh:and sh:xone) ] ?list .
    ?list list:member ?shape2 .
} 
=> 
{ 
    ?shape1 this:refers ?shape2 .
} .

{ ?shape1 this:refersStar ?shape2 } <= { ?shape1 this:refers ?shape2 } .
{ ?shape1 this:refersStar ?shape2 } <= { ?shape1 this:refers [ this:refersStar ?shape2 ] } .

{ ?shape this:refersStar ?shape } => false . # recursive shapes are not supported in this implementation