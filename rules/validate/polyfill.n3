### list:unique
@prefix list: <http://www.w3.org/2000/10/swap/list#> .
@prefix this: <http://eye-shacl#> .


{ () this:unique () } <= { } .

{ ?list this:unique ?result } <= { 
    ?list list:firstRest (?first ?rest) .
    ?first list:in ?rest .
    ?rest this:unique ?result .
} .

{ ?list this:unique ?result } <= { 
    ?list list:firstRest (?first ?rest) .
    ?rest list:notMember ?first .
    ?rest this:unique ?uniqueRest .
    ?result list:firstRest (?first ?uniqueRest) .
} .