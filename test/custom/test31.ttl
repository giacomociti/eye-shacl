@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .

# shapes


ex:shape
  sh:targetClass ex:City ;
  sh:node ex:cityShape
.

ex:cityShape
  sh:property [
    sh:path ex:name ;
    sh:equals foaf:name ;
  ] .


# data

ex:valid1 a ex:City ; ex:name "Paris" ; foaf:name "Paris" .
ex:valid2 a ex:City .
ex:invalid1 a ex:City ; ex:name "Paris" ; foaf:name "paris" .
ex:invalid2 a ex:City ; ex:name "Paris" .
ex:invalid3 a ex:City ; foaf:name "Paris" .
ex:invalid4 a ex:City ; ex:name "Paris", "Parigi"@it ; foaf:name "Paris" .


<>
  rdf:type mf:Manifest ;
  mf:entries (
      <test31>
    ) ;
.
<test31>
  rdf:type sht:Validate ;
  rdfs:label "Test 31" ;
  rdfs:comment "EqualsConstraintComponent inside a node shape";
  mf:action [
      sht:dataGraph <> ;
      sht:shapesGraph <> ;
    ] ;
  mf:result [
      rdf:type sh:ValidationReport ;
      sh:conforms "false"^^xsd:boolean ;
      sh:result [
        a sh:ValidationResult ;
        sh:resultSeverity sh:Violation ;
        sh:sourceConstraintComponent sh:NodeConstraintComponent ;
        sh:sourceShape <http://example.org/shape> ;
        sh:focusNode <http://example.org/invalid1> ;
        sh:value <http://example.org/invalid1> ;
      ] , [
        a sh:ValidationResult ;
        sh:resultSeverity sh:Violation ;
        sh:sourceConstraintComponent sh:NodeConstraintComponent ;
        sh:sourceShape <http://example.org/shape> ;
        sh:focusNode <http://example.org/invalid2> ;
        sh:value <http://example.org/invalid2> ;
      ] , [
        a sh:ValidationResult ;
        sh:resultSeverity sh:Violation ;
        sh:sourceConstraintComponent sh:NodeConstraintComponent ;
        sh:sourceShape <http://example.org/shape> ;
        sh:focusNode <http://example.org/invalid3> ;
        sh:value <http://example.org/invalid3> ;
      ] , [
        a sh:ValidationResult ;
        sh:resultSeverity sh:Violation ;
        sh:sourceConstraintComponent sh:NodeConstraintComponent ;
        sh:sourceShape <http://example.org/shape> ;
        sh:focusNode <http://example.org/invalid4> ;
        sh:value <http://example.org/invalid4> ;
      ] ;
    ] ;
  mf:status sht:approved ;
.
