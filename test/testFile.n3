@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .

{
    ?validate a sht:Validate ;
        mf:action [
            sht:dataGraph [ log:uri ?dataGraph ] ;
            sht:shapesGraph [ log:uri ?shapesGraph ] ;
        ] .
    (?dataGraph "file://" "") string:replace ?dataArg .
    (?shapesGraph "file://" "") string:replace ?shapesArg .
    
    ("../dist/eye-shacl.sh " ?shapesArg " " ?dataArg) string:concatenation ?args
}
=>
{
    [] log:outputString ?args.
} .